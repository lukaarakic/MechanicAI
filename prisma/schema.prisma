// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  firstName String
  lastName  String
  avatar    String
  tokens    Int
  // 
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  // 
  car       Car[]
  password  Password?
  solution  Solution[]
}

model Password {
  hash   String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId String @unique
}

model Car {
  id         String     @id @default(cuid())
  carBrand   String
  carModel   String
  year       String
  fuel       String
  engineSize String
  power      String
  shifter    String
  defaultCar Boolean    @default(false)
  // 
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  //
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  Solution   Solution[]
}

model Solution {
  id              String   @id @default(cuid())
  solution        String
  solutionTitle   String
  category        String?
  // 
  problem         String
  diagnostic      String
  dashboardLights String
  // 
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  // 
  carId           String?
  car             Car?     @relation(fields: [carId], references: [id])
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Verification {
  id        String    @id @default(cuid())
  type      String
  target    String
  secret    String
  algorithm String
  digits    Int
  period    Int
  charSet   String
  expiresAt DateTime?
  // 
  createdAt DateTime  @default(now())

  @@unique([target, type])
}

model WaitlistEmail {
  id    String @id @default(cuid())
  email String
}
